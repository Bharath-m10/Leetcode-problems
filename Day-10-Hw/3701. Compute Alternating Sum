class Solution {
    public int alternatingSum(int[] nums) {
        int sum = 0;
        for (int i = 0; i < nums.length; i++) {
            if (i % 2 == 0) {
                sum += nums[i]; // Add numbers at even indices (0, 2, 4...)
            } else {
                sum -= nums[i]; // Subtract numbers at odd indices (1, 3, 5...)
            }
        }
        return sum;
    }
}
