//263. Ugly Number
class Solution {
    public boolean isUgly(int n) {
        if (n <= 0) return false;
        
        // Repeatedly divide by 2, 3, and 5
        while (n % 2 == 0) n /= 2;
        while (n % 3 == 0) n /= 3;
        while (n % 5 == 0) n /= 5;
        
        // If the remaining value is 1, it only had factors of 2, 3, or 5
        return n == 1;
    }
}
