//2427. Number of Common Factors
class Solution {
    public int commonFactors(int a, int b) {
        int count = 0;
        // Find the minimum of a and b to limit our loop
        int min = Math.min(a, b);
        
        // Iterate from 1 to the smaller number
        for (int i = 1; i <= min; i++) {
            // Check if i divides both a and b
            if (a % i == 0 && b % i == 0) {
                count++;
            }
        }
        return count;
    }
}
