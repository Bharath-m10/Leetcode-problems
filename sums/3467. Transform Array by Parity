class Solution {
    public int[] transformArray(int[] nums) {
        int zeros = 0;
        int ones = 0;

        for (int num : nums) {
            if (num % 2 == 0) {
                zeros++;
            } else {
                ones++;
            }
        }

        int[] result = new int[nums.length];
        for (int i = 0; i < zeros; i++) {
            result[i] = 0;
        }
        for (int i = zeros; i < nums.length; i++) {
            result[i] = 1;
        }

        return result;
    }
}
