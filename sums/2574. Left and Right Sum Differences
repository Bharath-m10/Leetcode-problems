class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int[] answer = new int[n];
        
        int leftSum = 0;
        int rightSum = 0;
        
        // Calculate total sum of the array
        for (int num : nums) {
            rightSum += num;
        }
        
        // For each index, rightSum becomes the sum of elements to the right
        // and leftSum is the sum of elements to the left
        for (int i = 0; i < n; i++) {
            rightSum -= nums[i];
            answer[i] = Math.abs(leftSum - rightSum);
            leftSum += nums[i];
        }
        
        return answer;
    }
}
