class Solution {
    public int[] getSneakyNumbers(int[] nums) {
        int[] result = new int[2];
        int count = 0;
        
        // Using a frequency array since 0 <= nums[i] < n
        int[] freq = new int[nums.length];
        
        for (int num : nums) {
            freq[num]++;
            if (freq[num] == 2) {
                result[count++] = num;
            }
        }
        
        return result;
    }
}
